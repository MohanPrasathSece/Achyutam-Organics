# Environment Variables for Shiprocket Integration

# Shiprocket API Credentials
SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# Pickup Address (Your Business Address)
SHIPROCKET_PICKUP_NAME=Achyutam Organics
SHIPROCKET_PICKUP_PHONE=+919876543210
SHIPROCKET_PICKUP_ADDRESS=123 Farm Road, Katni
SHIPROCKET_PICKUP_CITY=Katni
SHIPROCKET_PICKUP_STATE=Madhya Pradesh
SHIPROCKET_PICKUP_PINCODE=483775
SHIPROCKET_PICKUP_COUNTRY=India

# Default Package Dimensions (in cm)
DEFAULT_PACKAGE_LENGTH=10
DEFAULT_PACKAGE_BREADTH=10
DEFAULT_PACKAGE_HEIGHT=5
DEFAULT_PACKAGE_WEIGHT=0.5

# Shipping Settings
ENABLE_COD=true
DEFAULT_SHIPPING_CHARGES=60
COD_CHARGES_EXTRA=20
